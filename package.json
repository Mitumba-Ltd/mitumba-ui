    "@mui/icons-material": "^7.3.11",
    "vercel": "^54.4.1"
  },
  "overrides": {
    "storybook": "8.6.14",
    "@storybook/core": "8.6.14",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "yaml": "2.9.0"
